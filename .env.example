# CodeAtlas Configuration
# Copy to backend/.env and fill in values

# OAuth - GitHub (https://github.com/settings/developers)
CODEATLAS_GITHUB_CLIENT_ID=
CODEATLAS_GITHUB_CLIENT_SECRET=

# OAuth - Google (https://console.cloud.google.com/apis/credentials)
CODEATLAS_GOOGLE_CLIENT_ID=
CODEATLAS_GOOGLE_CLIENT_SECRET=

# LLM API Keys (server-level fallback)
CODEATLAS_ANTHROPIC_API_KEY=

# JWT & Encryption (auto-generated if empty)
CODEATLAS_JWT_SECRET=
CODEATLAS_ENCRYPTION_KEY=

# Frontend URL for OAuth redirects
CODEATLAS_FRONTEND_URL=http://localhost:5173

# Database
CODEATLAS_DATABASE_PATH=codeatlas.db

# Neo4j (optional)
# CODEATLAS_USE_NEO4J=true
# CODEATLAS_NEO4J_URI=bolt://localhost:7687
# CODEATLAS_NEO4J_USER=neo4j
# CODEATLAS_NEO4J_PASSWORD=codeatlas

# Rate Limiting
# CODEATLAS_RATE_LIMIT_DEFAULT=60/minute
# CODEATLAS_RATE_LIMIT_INGEST=10/minute
# CODEATLAS_RATE_LIMIT_RAG=20/minute
